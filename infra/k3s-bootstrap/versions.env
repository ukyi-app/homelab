#!/usr/bin/env bash
# 호스트 기반 계층이 쓰는 외부 유래 버전 전부의 SSOT.
# install/storage 스크립트와 CI 체크가 source 한다 (직접 실행은 절대 안 함).

# k3s 릴리스 채널 태그 (고정 — 'stable'/'latest' 금지, cattle 재구축이 결정적이도록).
export K3S_VERSION="v1.36.2+k3s1"

# 게스트 OS.
export DEBIAN_RELEASE="bookworm"            # Debian 12, arm64
export DEBIAN_ARCH="arm64"

# rancher/local-path-provisioner 차트/앱 버전 (Task 1.7에서 매니페스트를 벤더링한다).
export LOCAL_PATH_PROVISIONER_VERSION="v0.0.36"

# HelperPod 이미지 — local-path가 노드에서 PV 디렉토리 mkdir/rm 에 사용한다.
# arm64 digest로 고정해 재현 가능하고 amd64를 조용히 끌어오는 일이 없게 한다.
export LOCAL_PATH_HELPER_IMAGE="busybox:1.36@sha256:73aaf090f3d85aa34ee199857f03fa3a95c8ede2ffd4cc2cdb5b94e566b11662"

# VM 사이징 (R3 + 메모리 예산 §10): 상한 11 GiB, 6 vCPU, 머신 하나.
export ORB_MEMORY_MIB="11264"               # 11 GiB
export ORB_CPU="6"

# 노드 로컬 스토리지 경로.
# internal: VM 자체 디스크 위, cloud-init이 생성 (Task 1.4).
export INTERNAL_STORAGE_PATH="/var/lib/rancher/k3s-storage/internal"   # 내장 SSD(VM /dev/vdb1, btrfs ~224GiB 실측)
# bulk: 외장 SSD 위, OrbStack이 virtiofs 마운트로 VM에 공유한다. 외장 'homelab' APFS
# 볼륨과 이 디렉토리는 docs/runbooks/external-ssd.md 에 따라 프로비저닝되고
# apply-storage.sh의 외장 SSD 게이트(Pass-5 Open Item #1)가 강제하므로, SSD가 없거나
# 쓰기 불가하면 bulk가 VM 디스크에 조용히 놓이는 대신(cattle 재구축 시 유실) 요란하게 실패한다.
export BULK_EXTERNAL_HOST_PATH="/Volumes/homelab"                     # 외장 SSD의 macOS 마운트 (호스트 측 diskutil 검사)
export BULK_EXTERNAL_MOUNT="/mnt/mac${BULK_EXTERNAL_HOST_PATH}"        # 같은 볼륨의 VM 내부 시점 (OrbStack virtiofs)
export BULK_STORAGE_PATH="${BULK_EXTERNAL_MOUNT}/k3s-bulk"             # bulk-ssd 노드 경로 (VM 내부)
# dev/이너루프 폴백, apply-storage.sh가 BULK_ALLOW_VM_DISK=1 로 실행될 때만 사용.
# bulk를 VM 디스크에 놓는다(재구축 시 비영속) — 실데이터에는 절대 금지.
export BULK_VM_DISK_FALLBACK="/var/lib/rancher/k3s-storage/bulk"
