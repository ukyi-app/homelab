# GitHub root 식별자 템플릿 (커밋되는 레퍼런스 — 시크릿 아님)
# 사용법: cp terraform.tfvars.example terraform.tfvars  (사본은 *.tfvars로 gitignored)
#
# ⚠️ 시크릿(github_token / telegram_*)은 여기 넣지 말 것 — .env.secrets의
#    TF_VAR_* (env)로만 공급된다.
#
# 이 루트는 owner 로컬 apply 전용 — "신뢰 앵커"다(Actions 시크릿·branch protection을 스스로 관리).
# CI에서 무인 apply하면 repo admin PAT를 CI에 저장해야 해 보안 모델 위반 → 절대 금지.
# 선택: tf-reconcile.yaml의 plan-only 드리프트 알림을 켜려면 아래 Actions 시크릿을 등록한다
#       (없으면 preflight가 skip) — TF_GITHUB_TOKEN(읽기 가능 PAT) / TF_GITHUB_OWNER.
#       TELEGRAM_*는 기존 시크릿 재사용.

# github.com 실제 계정명 (프로필 URL 기준 — git 커밋 이름과 다를 수 있음).
# 전제: github.com/<owner>/homelab repo가 이미 존재해야 한다 (private 권장).
github_owner = "<GH_USER>"

# repo 이름 (기본값 유지 권장 — terraform이 이 repo의 설정/branch protection/Actions secrets를 관리)
repo_name = "homelab"

# (선택) bump-poll/** 예약 ruleset의 bypass writer App slug. 시크릿 아님. 신뢰 앵커라 기본값에 pin(bats 강제).
# ⚠️ App 리네임은 이 변수만으로 안 된다 — 룰셋 변수 + bump-poll.yaml git 신원(user.name/email) +
#    ensure-bump-pr.ts DEFAULT_WRITER를 **동시 갱신**해야 한다. 안 그러면 룰셋은 리네임 App을 bypass하는데
#    실행기는 옛 신원을 신뢰/커밋해 bump 상태기계가 fail-closed. 그 3곳 조율 없이 이 값만 바꾸지 말 것.
# writer_app_slug = "ukyi-homelab-writer"
