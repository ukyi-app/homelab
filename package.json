{
  "name": "homelab",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=11"
  },
  "scripts": {
    "dev": "node tools/dev.mjs",
    "db:up": "node tools/dev.mjs db:up",
    "db:reset": "node tools/dev.mjs db:reset",
    "db:url": "node tools/db-url.mjs",
    "cache:url": "node tools/cache-url.mjs",
    "env:example": "node tools/env-example.mjs",
    "secret:seal": "node tools/seal-secret.mjs",
    "verify:ledger": "scripts/ledger-to-json.sh docs/memory-ledger.md > /tmp/ledger.json && conftest test /tmp/ledger.json --policy policy/ledger.rego",
    "verify:skeleton": "./scripts/check-skeleton.sh"
  },
  "devDependencies": {
    "yaml": "^2.9.0"
  }
}
