{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["image", "kind", "resources"],
  "properties": {
    "image": {
      "type": "object", "additionalProperties": false, "required": ["repo"],
      "properties": {
        "repo": { "type": "string", "minLength": 1 },
        "tag": { "type": "string", "pattern": "^$|^sha-[0-9a-f]{7,40}$" },
        "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "pullPolicy": { "type": "string", "enum": ["IfNotPresent", "Always", "Never"] }
      },
      "anyOf": [
        { "required": ["digest"] },
        { "required": ["tag"], "properties": { "tag": { "minLength": 1 } } }
      ]
    },
    "kind": { "type": "string", "enum": ["web", "worker", "site"] },
    "replicas": { "type": "integer", "minimum": 1, "maximum": 3 },
    "imagePullSecrets": { "type": "array", "items": { "type": "object" } },
    "podAnnotations": { "type": "object", "additionalProperties": { "type": "string" } },
    "gateway": {
      "type": "object", "additionalProperties": false,
      "properties": { "name": { "type": "string", "minLength": 1 }, "namespace": { "type": "string", "minLength": 1 } }
    },
    "resources": {
      "comment": "cpu·memory request + cpu·memory limit 4값 전부 required — 온보딩 사이징 디시플린(값 상속 금지, 앱 저자가 명시 선언). platform/ 베스포크의 check-resource-limits는 cpu limit 비요구(런타임 SRE=CFS throttling 회피)지만 이 차트는 apps/를 지배하는 별개 레이어라 정책이 다르다(분리 트리·게이트 무충돌). cpu limit 값은 저자 자유(넉넉히 두면 throttling 회피).",
      "type": "object", "required": ["requests", "limits"],
      "properties": {
        "requests": { "type": "object", "required": ["cpu", "memory"], "properties": { "cpu": { "type": "string", "minLength": 1 }, "memory": { "type": "string", "minLength": 1 } } },
        "limits":   { "type": "object", "required": ["cpu", "memory"], "properties": { "cpu": { "type": "string", "minLength": 1 }, "memory": { "type": "string", "minLength": 1 } } }
      }
    },
    "envFrom": { "type": "array", "items": { "type": "object" } },
    "route": {
      "type": "object", "additionalProperties": false,
      "properties": { "host": { "type": "string" }, "paths": { "type": "array", "items": { "type": "string" } }, "public": { "type": "boolean" } }
    },
    "homepage": {
      "type": "object", "additionalProperties": false,
      "properties": { "enabled": { "type": "boolean" }, "name": { "type": "string" }, "group": { "type": "string" }, "icon": { "type": "string" } }
    },
    "probes": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "liveness": { "type": "object", "additionalProperties": false, "properties": { "path": { "type": "string" } } },
        "readiness": { "type": "object", "additionalProperties": false, "properties": { "path": { "type": "string" } } }
      }
    },
    "static": {
      "type": "object", "additionalProperties": false,
      "properties": { "server": { "type": "string", "enum": ["sws"] } }
    },
    "ports": {
      "type": "object", "additionalProperties": false,
      "comment": "http=8080·metrics=9090은 const로 고정 — prod ns-wide NetworkPolicy(platform/network-policies/prod/networkpolicies.yaml)가 이 두 포트를 하드코딩한다(gateway→8080 ingress, observability→9090 scrape, kubelet probe→8080). 커스텀 포트를 넣으면 렌더는 통과하나 gateway→pod가 default-deny로 드롭되고 kubelet probe는 노드발이라 통과 → 파드 Ready·ArgoCD green인 채 공개 edge만 502(무성 실패). 포트를 바꾸려면 netpol과 이 const를 반드시 동시에 갱신한다.",
      "properties": {
        "http": { "type": "integer", "const": 8080, "default": 8080 },
        "metrics": { "type": "integer", "const": 9090, "default": 9090 }
      }
    },
    "metrics": {
      "type": "object", "additionalProperties": false,
      "properties": { "enabled": { "type": "boolean" } }
    },
    "livenessProbe": { "type": "object" },
    "automountServiceAccountToken": { "type": "boolean" },
    "strategy": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["Recreate", "RollingUpdate"] },
        "rollingUpdate": { "type": "object" }
      }
    },
    "podSecurityContext": {
      "type": "object",
      "comment": "약화 거부(fast-feedback) — 전체 PSA restricted 패리티는 chart-test conftest(psa-restricted.rego)가 렌더 검증.",
      "not": { "anyOf": [
        { "required": ["runAsUser"], "properties": { "runAsUser": { "const": 0 } } },
        { "required": ["runAsNonRoot"], "properties": { "runAsNonRoot": { "const": false } } }
      ] }
    },
    "securityContext": {
      "type": "object",
      "comment": "약화 거부(fast-feedback) — 전체 PSA restricted 패리티는 chart-test conftest가 렌더 검증.",
      "not": { "anyOf": [
        { "required": ["privileged"], "properties": { "privileged": { "const": true } } },
        { "required": ["allowPrivilegeEscalation"], "properties": { "allowPrivilegeEscalation": { "const": true } } },
        { "required": ["runAsUser"], "properties": { "runAsUser": { "const": 0 } } }
      ] }
    },
    "terminationGracePeriodSeconds": { "type": "integer" },
    "preStopSleepSeconds": { "type": "integer", "minimum": 0 }
  }
}
