# ═══════════════════════════════════════════════════════════════════════════════
# M2 라이브 bring-up 시크릿 템플릿 (커밋되는 레퍼런스 — 실제 값 금지)
#
# 사용법:
#   cp .env.secrets.example .env.secrets    # 복사본은 gitignored (.env.*)
#   $EDITOR .env.secrets                    # 별도 tmux 창에서 편집 (값을 채팅에 붙여넣지 말 것)
#   set -a; source .env.secrets; set +a     # terraform / seed-secrets.sh 실행 전 export
#
# 여기엔 시크릿 토큰만. 식별자(도메인/account id/github owner/tailscale ip)는
# infra/<root>/terraform.tfvars 에, R2 state 버킷 자격증명은 infra/<root>/backend.hcl 에.
# (둘 다 gitignored)
# ═══════════════════════════════════════════════════════════════════════════════

# ── ① Cloudflare API token (terraform provider 인증) ───────────────────────────
# 발급: dash.cloudflare.com → 우상단 프로필 → My Profile → API Tokens
#       → Create Token → Create Custom Token
# 권한: [Account] Workers R2 Storage:Edit, Cloudflare Tunnel:Edit
#       [Zone]    DNS:Edit, Zone:Read, Zone WAF:Edit, Cache Rules:Edit
#       Zone Resources: 해당 zone만 지정
export TF_VAR_cloudflare_api_token=""

# ── ② Tailscale OAuth client (terraform provider 인증) ──────────────────────────
# ⚠️ 사전 작업: devices:core/auth_keys 스코프는 태그 필수 → admin/acls 에서 먼저
#   tagOwners 에 "tag:k8s-operator": ["autogroup:admin"], "tag:k8s": ["tag:k8s-operator"]
#   를 추가/저장해야 태그가 선택지에 뜸 (terraform acl.tf와 동일 정의라 이후 apply와 수렴)
# 발급: login.tailscale.com/admin/settings/oauth → Generate OAuth client
# 스코프(Write): policy_file, dns, oauth_keys, devices:core, auth_keys
#   (oauth_keys/devices:core/auth_keys 에는 tag:k8s-operator 태그 지정)
#   (terraform이 ACL·split-DNS·operator용 OAuth client를 만들므로 전부 필요)
export TF_VAR_ts_bootstrap_oauth_id=""
export TF_VAR_ts_bootstrap_oauth_secret=""

# ── ③ GitHub repo 관리 토큰 ─────────────────────────────────────────────────────
# 발급: github.com/settings/tokens → Generate new token (classic) → 스코프 'repo' 전체
#   (homelab repo의 설정/branch protection/Actions secrets 관리용)
export TF_VAR_github_token=""

# ── ⑤ Telegram 봇 토큰 + chat_id (CI 알림용 — infra/github/secrets.tf가 소비) ──────
# 이 TF_VAR 쌍은 terraform(infra/github)이 GitHub Actions secret
#   TELEGRAM_BOT_TOKEN / TELEGRAM_CHAT_ID 로 올린다 (워크플로 알림이 이걸 읽음).
#   ⚠️ 절대 삭제 금지 — 지우면 CI Telegram 알림이 죽는다.
# ⑦(seed-secrets.sh가 읽는 동명 쌍)과 반드시 *동일한 값*이어야 한다.
#   같은 봇/같은 chat을 CI(Actions)와 클러스터(Alertmanager) 양쪽이 써야 하므로.
# 토큰: Telegram에서 @BotFather → /newbot → 토큰 복사
# chat_id: 만든 봇에게 아무 메시지 전송 후
#   https://api.telegram.org/bot<토큰>/getUpdates 에서 "chat":{"id":숫자} 복사
export TF_VAR_telegram_bot_token=""
export TF_VAR_telegram_chat_id=""

# ═══ 아래는 seed-secrets.sh 용 (terraform과 별도로 읽음) ═══════════════════════════

# ── ⑥ R2 API token — CNPG 백업/hedge용 (state 버킷 토큰과 같아도 됨) ─────────────
# 발급: dash.cloudflare.com → R2 Object Storage → API → Manage API Tokens
#       → Create API Token → Permissions: Object Read & Write → Apply to all buckets
# 생성 직후 Access Key ID / Secret Access Key 복사 (한 번만 표시됨!)
# ※ 같은 키를 infra/*/backend.hcl(state용)에도 쓸 수 있음
export R2_PG_ACCESS_KEY=""
export R2_PG_SECRET_KEY=""

# ── ⑦ Telegram (seed-secrets.sh가 이 이름을 읽어 k8s SOPS 시크릿으로 봉인) ─────────
# ⑤와 *동일한 값*. 단일 출처를 위해 기본은 ⑤에서 파생시킨다(아래 확장).
# 다른 봇/chat을 쓸 특별한 이유가 없으면 이 두 줄을 그대로 두면 된다.
# (source 순서상 ⑤가 위에서 먼저 export되므로 확장이 채워진다.)
export TELEGRAM_BOT_TOKEN="${TF_VAR_telegram_bot_token}"
export TELEGRAM_CHAT_ID="${TF_VAR_telegram_chat_id}"

# ── ⑧ healthchecks.io ping URL (dead-man switch, R8) ───────────────────────────
# 발급: healthchecks.io 가입 → Add Check → 이름 정확히 'homelab-watchdog'
#       (Makefile 게이트가 이 이름 확인) → ping URL 복사 (https://hc-ping.com/<uuid>)
export HEALTHCHECKS_URL=""

# ── ⑨ Grafana admin 비밀번호 (직접 생성; admin/admin 금지) ──────────────────────
# 생성 예: openssl rand -base64 24   (비밀번호 관리자에도 보관 권장)
export GRAFANA_ADMIN_PASSWORD=""

# ── ⑩ AdGuard UI 관리자 비밀번호 (username은 deployment에 평문 'ukkiee') ─────────
# 생성 예: openssl rand -base64 24   (비밀번호 관리자에도 보관 권장)
# 이 평문은 봉인에만 쓰인다 — 별도 tooling이 자동 소비하지 않는다. 값을 채운 뒤:
#   make seal-adguard-auth   (로컬에서 bcrypt 해시 생성→kubeseal로 platform/adguard/prod/adguard-auth.sealed.yaml 봉인)
# 평문/해시는 출력·커밋되지 않고, 봉인된 SealedSecret(adguard-auth)만 git에 들어간다.
export ADGUARD_PASSWORD=""

# ── ⑪ ArgoCD UI 로컬 계정 ukkiee 비밀번호 (8–32자) ──────────────────────────────
# argocd UI(argocd.home.ukyi.app) 로그인 계정 ukkiee의 비밀번호. argocd account bcrypt로 해시 →
# patch-mode SealedSecret(argocd-secret)로 봉인. 값을 채팅/로그에 붙여넣지 말 것.
export ARGOCD_PASSWORD=""
