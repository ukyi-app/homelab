# Template for the M2 live bring-up secrets. COMMITTED reference (no real values here).
#
# Usage:
#   cp .env.secrets.example .env.secrets   # the copy is gitignored (.env.*)
#   $EDITOR .env.secrets                   # fill in real values — NEVER paste them into chat
#   set -a; source .env.secrets; set +a    # export into the shell before terraform / seed-secrets
#
# Only SECRET tokens live here. Non-secret IDENTIFIERS (domain, account id, github owner,
# tailscale ip) go in infra/<root>/terraform.tfvars. R2 *state-bucket* creds go in
# infra/<root>/backend.hcl. (Those two are also gitignored.)

# ── Cloudflare — terraform provider auth ───────────────────────────────────────
# Dashboard → My Profile → API Tokens → Create Token. Scopes (Account+Zone):
#   Zone:Edit, DNS:Edit, Workers R2 Storage:Edit, Cloudflare Tunnel:Edit
export TF_VAR_cloudflare_api_token=""

# ── Tailscale — terraform provider auth ────────────────────────────────────────
# Admin console → Settings → OAuth clients → Generate. The client provisions the
# k8s operator (tag:k8s-operator). Copy BOTH the id and the secret.
export TF_VAR_ts_bootstrap_oauth_id=""
export TF_VAR_ts_bootstrap_oauth_secret=""

# ── GitHub — terraform provider auth + repo Actions secrets it sets ────────────
# github_token: a token that can ADMIN the <owner>/homelab repo (classic 'repo' scope,
#   or a fine-grained PAT with Administration + Secrets read/write on that repo).
export TF_VAR_github_token=""
# bot_pat: a SEPARATE fine-grained PAT used by the CI write-back bot to push the
#   serialized image-tag bump to values.yaml (Contents:write on the repo).
export TF_VAR_bot_pat=""
# Telegram bot (create via @BotFather → /newbot). chat_id: message the bot then read
#   https://api.telegram.org/bot<TOKEN>/getUpdates, or use @userinfobot.
export TF_VAR_telegram_bot_token=""
export TF_VAR_telegram_chat_id=""

# ── seed-secrets.sh — Kubernetes seed Secrets (separate from Terraform) ────────
# R2 API token (Object Read & Write) for the CNPG backups/hedge. May be the SAME
# token as the state-bucket one, or a separate scoped token. (R2 → Manage API Tokens.)
export R2_PG_ACCESS_KEY=""
export R2_PG_SECRET_KEY=""
# Same values as the TF_VAR_telegram_* above (seed-secrets reads these exact names):
export TELEGRAM_BOT_TOKEN=""
export TELEGRAM_CHAT_ID=""
# healthchecks.io → New Check → copy its ping URL (the dead-man switch, R8):
export HEALTHCHECKS_URL=""
# Grafana admin password — pick a strong one (the chart refuses admin/admin):
export GRAFANA_ADMIN_PASSWORD=""
