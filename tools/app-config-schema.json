{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "app-config-schema",
  "title": ".app-config.yml — 외부 앱 레포의 자기선언 v2 (create-app이 values.yaml + .bindings.json으로 변환)",
  "description": "앱 연결(DB/Redis)은 앱 SealedSecret의 DATABASE_URL/REDIS_URL로 주입한다(별도 db/redis 필드 없음). create-app이 secrets(SealedSecret)·env·digest 핀 이미지를 검증해 values.yaml + .bindings.json(autoDeploy)으로 변환한다. 마이그레이션은 앱이 부팅 시 self-migrate(expand/contract+멱등).",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "resources"],
  "properties": {
    "kind": { "enum": ["service", "worker", "static"] },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requests", "limits"],
      "properties": {
        "requests": { "$ref": "#/definitions/rr" },
        "limits": { "$ref": "#/definitions/rr" }
      }
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "public": { "type": "boolean", "default": false },
        "host": { "type": "string", "pattern": "^[a-z0-9.-]+$" },
        "paths": { "type": "array", "items": { "type": "string", "pattern": "^/" }, "minItems": 1 }
      }
    },
    "replicas": { "type": "integer", "minimum": 1, "maximum": 3 },
    "env": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "value"],
        "properties": {
          "name": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
          "value": { "type": "string" }
        }
      }
    },
    "allowPlaintext": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" }
    },
    "secrets": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" }
    },
    "probes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "liveness": { "$ref": "#/definitions/probe" },
        "readiness": { "$ref": "#/definitions/probe" }
      }
    },
    "static": {
      "type": "object",
      "additionalProperties": false,
      "properties": { "server": { "enum": ["sws"] } }
    },
    "deploy": {
      "type": "object",
      "additionalProperties": false,
      "properties": { "autoDeploy": { "type": "boolean", "default": true } }
    }
  },
  "definitions": {
    "rr": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cpu", "memory"],
      "properties": {
        "cpu": { "type": "string", "pattern": "^[0-9]+m?$" },
        "memory": { "type": "string", "pattern": "^[0-9]+(Mi|Gi)$" }
      }
    },
    "probe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": { "path": { "type": "string", "pattern": "^/" } }
    }
  }
}
