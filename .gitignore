age.key
*.age
key.txt
keys.txt
.env
.env.*
!.env.example
*.decrypted.yaml
*.dec.yaml

# --- Terraform ---
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
backend.hcl
crash.log
override.tf
override.tf.json

# --- SOPS plaintext scratch ---
*.tmp.yaml

# --- Kubeconfig / cluster creds ---
kubeconfig
*.kubeconfig
.kube/

# --- Node / pnpm ---
node_modules/
dist/
build/
.turbo/
*.tsbuildinfo
.pnpm-store/

# --- Local Claude tooling / runtime state ---
.claude/

# --- OS / editor ---
.DS_Store
*.swp
.idea/
.vscode/*
